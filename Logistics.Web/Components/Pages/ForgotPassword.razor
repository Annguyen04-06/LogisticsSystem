@page "/forgot-password"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Quên mật khẩu</PageTitle>

<div class="auth-page auth-page-modern">
    <div class="auth-floating-shape shape-one"></div>
    <div class="auth-floating-shape shape-two"></div>

    <div class="auth-card auth-shell slide-up">
        <section class="auth-brand">
            <div class="auth-brand-mark">LS</div>
            <h1>Hệ thống quản lý Logistics</h1>
            <p>Khôi phục quyền truy cập để tiếp tục quản lý đơn hàng, giao hàng và thanh toán.</p>
            <div class="auth-brand-points">
                <span><i class="bi bi-shield-check"></i> Bảo mật</span>
                <span><i class="bi bi-envelope-check"></i> Xác thực email</span>
                <span><i class="bi bi-clock-history"></i> Hết hạn sau 15 phút</span>
            </div>
        </section>

        <section class="auth-form">
            <div class="mb-4">
                <h2 class="auth-title">Quên mật khẩu</h2>
                <p class="auth-subtitle">Nhập email để nhận mã đặt lại mật khẩu.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@forgotPasswordRequest" OnValidSubmit="HandleForgotPassword">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control auth-input"
                               @bind-Value="forgotPasswordRequest.Email"
                               placeholder="Nhập email của bạn" />
                    <ValidationMessage For="@(() => forgotPasswordRequest.Email)" />
                </div>

                <button class="btn auth-button w-100" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "Đang xử lý..." : "Gửi mã đặt lại mật khẩu")
                </button>
            </EditForm>

            @if (hasSubmittedSuccessfully)
            {
                <button class="btn btn-soft-primary w-100 mt-3" type="button" @onclick="GoToResetPassword">
                    Nhập mã đặt lại mật khẩu
                </button>
            }

            <div class="text-center mt-4">
                <a class="auth-link" href="login">Quay lại đăng nhập</a>
            </div>
        </section>
    </div>
</div>

@code {
    private readonly ForgotPasswordRequest forgotPasswordRequest = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isSubmitting;
    private bool hasSubmittedSuccessfully;

    private async Task HandleForgotPassword()
    {
        errorMessage = null;
        successMessage = null;
        hasSubmittedSuccessfully = false;
        isSubmitting = true;

        try
        {
            var response = await AuthService.ForgotPasswordAsync(forgotPasswordRequest.Email);

            if (response?.Success == true)
            {
                successMessage = "Nếu email tồn tại trong hệ thống, hướng dẫn đặt lại mật khẩu đã được gửi.";
                hasSubmittedSuccessfully = true;
                return;
            }

            errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoToResetPassword()
    {
        Navigation.NavigateTo("/reset-password");
    }
}
