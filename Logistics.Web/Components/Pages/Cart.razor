@page "/cart"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject CartApiService CartApiService
@inject OrderApiService OrderApiService
@inject NavigationManager Navigation

<PageTitle>Giỏ hàng</PageTitle>

<div class="page-header fade-in">
    <div>
        <h1 class="page-title">Giỏ hàng của tôi</h1>
        <p class="page-subtitle">Kiểm tra sản phẩm và tạo đơn hàng.</p>
    </div>
    <button class="btn btn-soft-danger action-btn" @onclick="ClearCartAsync" disabled="@(cart.Items.Count == 0)">
        <i class="bi bi-trash"></i> Xóa giỏ hàng
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-modern fade-in">
        @successMessage
        @if (orderCreated)
        {
            <a class="alert-link ms-2" href="my-orders">Xem đơn hàng</a>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-modern fade-in">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state"><i class="bi bi-arrow-repeat"></i> Đang tải dữ liệu...</div>
}
else
{
    <div class="row g-3">
        <div class="col-xl-8">
            <div class="modern-card modern-table-wrapper slide-up">
                <div class="admin-card-header">
                    <div class="stat-icon"><i class="bi bi-cart3"></i></div>
                    <div>
                        <h2>Sản phẩm trong giỏ</h2>
                        <p>Kiểm tra số lượng trước khi đặt hàng.</p>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle modern-table mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (cart.Items.Count == 0)
                            {
                                <tr>
                                    <td colspan="5"><div class="empty-state"><i class="bi bi-cart-x"></i> Chưa có dữ liệu.</div></td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in cart.Items)
                                {
                                    <tr>
                                        <td class="fw-semibold"><span class="cart-item-name">@item.ProductName</span></td>
                                        <td class="currency-value">@FormatMoney(item.Price)</td>
                                        <td>
                                            <input class="form-control form-control-sm quantity-input" type="number" min="1" @bind="item.Quantity" />
                                        </td>
                                        <td class="fw-bold currency-value">@FormatMoney(item.TotalPrice)</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-soft-warning action-btn me-1" @onclick="() => UpdateCartItemAsync(item)">
                                                <i class="bi bi-pencil-square"></i> Cập nhật
                                            </button>
                                            <button class="btn btn-sm btn-soft-danger action-btn" @onclick="() => RemoveCartItemAsync(item.Id)">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <EditForm Model="@createOrder" OnValidSubmit="CreateOrderAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="modern-card customer-summary-card cart-summary-card p-4 mb-3 hover-lift">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted fw-semibold">Tổng tiền</span>
                        <span class="summary-money currency-value">@FormatMoney(cart.TotalAmount)</span>
                    </div>
                    <button class="btn btn-gradient-success w-100 action-btn" type="submit" disabled="@(cart.Items.Count == 0 || isSubmittingOrder)">
                        <i class="bi bi-receipt"></i> @(isSubmittingOrder ? "Đang đặt hàng..." : "Đặt hàng")
                    </button>
                </div>

                <div class="modern-card form-modern p-4 slide-up">
                    <h2 class="h5 fw-bold mb-3">Thông tin đặt hàng</h2>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ giao hàng</label>
                        <InputText class="form-control" @bind-Value="createOrder.ShippingAddress" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mã giảm giá</label>
                        <InputText class="form-control" @bind-Value="createOrder.CouponCode" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ghi chú</label>
                        <InputText class="form-control" @bind-Value="createOrder.Note" />
                    </div>
                    <div>
                        <label class="form-label">Phương thức thanh toán</label>
                        <InputSelect class="form-select" @bind-Value="createOrder.PaymentMethod">
                            <option value="COD">Thanh toán khi nhận hàng</option>
                            <option value="Wallet">Ví điện tử</option>
                            <option value="BankingDemo">Chuyển khoản giả lập</option>
                        </InputSelect>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private CartDto cart = new();
    private CreateOrderDto createOrder = new();
    private bool isLoading = true;
    private bool isSubmittingOrder;
    private bool orderCreated;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadCartAsync();
        StateHasChanged();
    }

    private async Task LoadCartAsync()
    {
        isLoading = true;
        var response = await CartApiService.GetMyCartAsync();
        cart = response?.Data ?? new CartDto();
        isLoading = false;
    }

    private async Task UpdateCartItemAsync(CartItemDto item)
    {
        successMessage = null;
        errorMessage = null;

        if (item.Quantity <= 0)
        {
            errorMessage = "Số lượng phải lớn hơn 0.";
            return;
        }

        var response = await CartApiService.UpdateCartItemAsync(item.Id, new UpdateCartItemDto { Quantity = item.Quantity });

        if (response?.Success == true && response.Data != null)
        {
            cart = response.Data;
            successMessage = "Đã cập nhật giỏ hàng.";
            return;
        }

        errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    private async Task RemoveCartItemAsync(int cartItemId)
    {
        successMessage = null;
        errorMessage = null;

        var response = await CartApiService.RemoveCartItemAsync(cartItemId);

        if (response?.Success == true && response.Data != null)
        {
            cart = response.Data;
            successMessage = "Đã xóa sản phẩm khỏi giỏ hàng.";
            return;
        }

        errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    private async Task ClearCartAsync()
    {
        successMessage = null;
        errorMessage = null;

        var response = await CartApiService.ClearCartAsync();

        if (response?.Success == true && response.Data != null)
        {
            cart = response.Data;
            successMessage = "Đã xóa giỏ hàng.";
            return;
        }

        errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    private async Task CreateOrderAsync()
    {
        successMessage = null;
        errorMessage = null;
        orderCreated = false;
        isSubmittingOrder = true;

        try
        {
            var response = await OrderApiService.CreateOrderAsync(createOrder);

            if (response?.Success == true)
            {
                successMessage = "Đặt hàng thành công";
                orderCreated = true;
                createOrder = new CreateOrderDto();
                await LoadCartAsync();
                return;
            }

            errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isSubmittingOrder = false;
        }
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} đ";
    }
}
