@page "/seller/products"
@page "/seller-products"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject SellerProductApiService SellerProductApiService
@inject CategoryApiService CategoryApiService
@inject UploadApiService UploadApi
@inject NavigationManager Navigation

<PageTitle>Quản lý sản phẩm</PageTitle>

<div class="page-header fade-in">
    <div>
        <h1 class="page-title">Quản lý sản phẩm</h1>
        <p class="page-subtitle">Thêm, cập nhật và ngừng bán sản phẩm của người bán.</p>
    </div>
    <button class="btn btn-gradient-primary action-btn" @onclick="StartCreate">
        <i class="bi bi-plus-circle"></i> Tạo sản phẩm
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-modern fade-in">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-modern fade-in">@errorMessage</div>
}

<div class="modern-card form-modern seller-product-form-card mb-3 slide-up">
    <div class="d-flex align-items-center gap-3 mb-3">
        <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
        <div>
            <h2 class="h5 fw-bold mb-0">@(editingProductId.HasValue ? "Cập nhật sản phẩm" : "Tạo sản phẩm")</h2>
            <div class="text-muted small">Nhập thông tin sản phẩm và tải ảnh minh họa nếu có.</div>
        </div>
    </div>
    <EditForm Model="@productForm" OnValidSubmit="SaveProductAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Tên sản phẩm</label>
                <InputText class="form-control" @bind-Value="productForm.Name" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Danh mục</label>
                <InputSelect class="form-select" @bind-Value="productForm.CategoryId">
                    <option value="0">Chọn danh mục</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </InputSelect>
            </div>
            <div class="col-12">
                <label class="form-label">Mô tả</label>
                <InputTextArea class="form-control" rows="3" @bind-Value="productForm.Description" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Giá</label>
                <InputNumber class="form-control" @bind-Value="productForm.Price" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Số lượng</label>
                <InputNumber class="form-control" @bind-Value="productForm.Quantity" />
            </div>
            @if (!editingProductId.HasValue)
            {
                <div class="col-md-4">
                    <div class="seller-image-field">
                        <label class="form-label">Ảnh sản phẩm</label>
                        <InputFile class="form-control" OnChange="OnCreateProductImageSelected" accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text">Hỗ trợ JPG, PNG, WEBP. Dung lượng tối đa 3MB.</div>
                        @if (createProductImage is not null)
                        {
                            <div class="selected-file-chip"><i class="bi bi-image"></i> @createProductImage.Name</div>
                        }
                    </div>
                </div>
            }
            @if (editingProductId.HasValue)
            {
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="productForm.IsActive" />
                        <label class="form-check-label">Đang bán</label>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button class="btn btn-gradient-success action-btn" type="submit" disabled="@isSaving">
                <i class="bi bi-save"></i> @(isSaving ? "Đang lưu..." : "Lưu")
            </button>
            @if (editingProductId.HasValue)
            {
                <button class="btn btn-soft-secondary action-btn" type="button" @onclick="StartCreate">Hủy</button>
            }
        </div>
    </EditForm>
</div>

@if (isLoading)
{
    <div class="loading-state"><i class="bi bi-arrow-repeat"></i> Đang tải dữ liệu...</div>
}
else
{
    <div class="modern-card table-card seller-products-table-card modern-table-wrapper slide-up">
        <div class="admin-card-header">
            <div class="stat-icon"><i class="bi bi-list-check"></i></div>
            <div>
                <h2>Danh sách sản phẩm</h2>
                <p>Quản lý ảnh, tồn kho và trạng thái bán.</p>
            </div>
        </div>
        <div class="table-responsive">
        <table class="table table-hover align-middle modern-table mb-0">
            <thead>
                <tr>
                    <th>Ảnh</th>
                    <th>Mã sản phẩm</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (products.Count == 0)
                {
                    <tr>
                        <td colspan="8"><div class="empty-state"><i class="bi bi-inbox"></i> Chưa có dữ liệu.</div></td>
                    </tr>
                }
                else
                {
                    @foreach (var product in products)
                    {
                        <tr>
                            <td>
                                <div class="seller-product-thumb">
                                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-box-seam"></i>
                                    }
                                </div>
                            </td>
                            <td>#@product.Id</td>
                            <td class="seller-product-name">@product.Name</td>
                            <td>@product.CategoryName</td>
                            <td class="seller-price-text currency-value">@product.Price.ToString("N0") đ</td>
                            <td>@product.Quantity</td>
                            <td>
                                <span class="status-badge @(product.IsActive ? "badge-soft-success" : "badge-soft-secondary")">
                                    @(product.IsActive ? "Đang bán" : "Ngừng bán")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="seller-action-stack">
                                <div class="seller-image-upload">
                                    <InputFile class="form-control form-control-sm" OnChange="args => OnProductImageSelected(product.Id, args)" accept=".jpg,.jpeg,.png,.webp" />
                                    <button class="btn btn-sm btn-soft-primary action-btn"
                                            type="button"
                                            disabled="@(!selectedProductImages.ContainsKey(product.Id) || uploadingProductId == product.Id)"
                                            @onclick="() => UploadProductImageAsync(product.Id)">
                                        <i class="bi bi-cloud-arrow-up"></i> @(uploadingProductId == product.Id ? "Đang xử lý..." : "Đổi ảnh")
                                    </button>
                                </div>
                                <div class="seller-action-row">
                                    <button class="btn btn-sm btn-soft-warning action-btn" @onclick="() => StartEdit(product)"><i class="bi bi-pencil-square"></i> Sửa</button>
                                    <button class="btn btn-sm btn-soft-danger action-btn" @onclick="() => DeleteProductAsync(product.Id)"><i class="bi bi-trash"></i> Xóa</button>
                                </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>
}

@code {
    private List<ProductDto> products = [];
    private List<CategoryDto> categories = [];
    private UpdateProductDto productForm = new();
    private IBrowserFile? createProductImage;
    private Dictionary<int, IBrowserFile> selectedProductImages = [];
    private int? editingProductId;
    private int? uploadingProductId;
    private bool isLoading = true;
    private bool isSaving;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadInitialDataAsync();
        StateHasChanged();
    }

    private async Task LoadInitialDataAsync()
    {
        isLoading = true;
        var categoriesResponse = await CategoryApiService.GetCategoriesAsync();
        categories = categoriesResponse?.Data ?? [];
        await LoadProductsAsync();
        isLoading = false;
    }

    private async Task LoadProductsAsync()
    {
        var response = await SellerProductApiService.GetMyProductsAsync();
        products = response?.Data ?? [];
    }

    private void StartCreate()
    {
        ResetProductForm();
        successMessage = null;
        errorMessage = null;
    }

    private void ResetProductForm()
    {
        editingProductId = null;
        productForm = new UpdateProductDto { IsActive = true };
        createProductImage = null;
    }

    private void StartEdit(ProductDto product)
    {
        editingProductId = product.Id;
        createProductImage = null;
        productForm = new UpdateProductDto
        {
            Name = product.Name,
            Description = product.Description,
            Price = product.Price,
            Quantity = product.Quantity,
            CategoryId = product.CategoryId,
            ImageUrl = product.ImageUrl,
            IsActive = product.IsActive
        };
        successMessage = null;
        errorMessage = null;
    }

    private async Task SaveProductAsync()
    {
        isSaving = true;
        successMessage = null;
        errorMessage = null;

        try
        {
            if (editingProductId.HasValue)
            {
                var updateResponse = await SellerProductApiService.UpdateAsync(editingProductId.Value, productForm);
                if (updateResponse?.Success != true)
                {
                    errorMessage = updateResponse?.Message ?? "Không thể cập nhật sản phẩm.";
                    return;
                }

                successMessage = "Cập nhật sản phẩm thành công.";
            }
            else
            {
                var createResponse = await SellerProductApiService.CreateAsync(productForm);
                if (createResponse?.Success != true || createResponse.Data is null)
                {
                    errorMessage = createResponse?.Message ?? "Không thể tạo sản phẩm.";
                    return;
                }

                successMessage = "Tạo sản phẩm thành công.";

                if (createProductImage is not null)
                {
                    var uploadResponse = await UploadApi.UploadProductImageAsync(createResponse.Data.Id, createProductImage);

                    if (uploadResponse?.Success == true)
                    {
                        successMessage = "Tạo sản phẩm thành công. Tải ảnh sản phẩm thành công.";
                    }
                    else
                    {
                        errorMessage = uploadResponse?.Message ?? "Sản phẩm đã được tạo nhưng không thể tải ảnh sản phẩm.";
                    }
                }
            }

            ResetProductForm();
            await LoadProductsAsync();
        }
        catch
        {
            errorMessage = "Không thể lưu sản phẩm.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteProductAsync(int productId)
    {
        successMessage = null;
        errorMessage = null;

        var response = await SellerProductApiService.DeleteAsync(productId);
        if (response?.Success == true)
        {
            successMessage = response.Message;
            await LoadProductsAsync();
            return;
        }

        errorMessage = response?.Message ?? "Không thể xóa sản phẩm.";
    }

    private void OnProductImageSelected(int productId, InputFileChangeEventArgs args)
    {
        selectedProductImages[productId] = args.File;
        successMessage = null;
        errorMessage = null;
    }

    private void OnCreateProductImageSelected(InputFileChangeEventArgs args)
    {
        createProductImage = args.File;
        successMessage = null;
        errorMessage = null;
    }

    private async Task UploadProductImageAsync(int productId)
    {
        successMessage = null;
        errorMessage = null;

        if (!selectedProductImages.TryGetValue(productId, out var file))
        {
            errorMessage = "Vui lòng chọn file ảnh.";
            return;
        }

        try
        {
            uploadingProductId = productId;
            var response = await UploadApi.UploadProductImageAsync(productId, file);

            if (response?.Success == true)
            {
                successMessage = "Tải ảnh sản phẩm thành công.";
                selectedProductImages.Remove(productId);
                await LoadProductsAsync();
                return;
            }

            errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            uploadingProductId = null;
        }
    }
}
