@page "/profile"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject ProfileApiService ProfileApi
@inject UploadApiService UploadApi
@inject NavigationManager Navigation

<PageTitle>Hồ sơ cá nhân</PageTitle>

<div class="page-header fade-in">
    <div>
        <h1 class="page-title">Hồ sơ cá nhân</h1>
        <p class="page-subtitle">Quản lý thông tin tài khoản, ảnh đại diện và mật khẩu.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-modern fade-in">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-modern fade-in">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state"><i class="bi bi-arrow-repeat"></i> Đang tải dữ liệu...</div>
}
else if (profile is null)
{
    <div class="empty-state"><i class="bi bi-inbox"></i> Chưa có dữ liệu.</div>
}
else
{
    <div class="profile-grid fade-in">
        <aside class="profile-left">
            <div class="modern-card profile-card profile-avatar-card text-center hover-lift">
                <div class="profile-avatar mx-auto mb-3">
                    @if (!string.IsNullOrWhiteSpace(profile.AvatarUrl))
                    {
                        <img src="@profile.AvatarUrl" alt="Ảnh đại diện" />
                    }
                    else
                    {
                        <span>@GetInitial(profile.FullName)</span>
                    }
                </div>

                <h2 class="h4 fw-bold mb-1">@profile.FullName</h2>
                <div class="text-muted">@profile.Email</div>
                <span class="role-badge mt-3">@DisplayRole(profile.Role)</span>
                <div class="mt-3">
                    <span class="status-badge @(profile.IsActive ? "badge-soft-success" : "badge-soft-danger")">
                        @(profile.IsActive ? "Đang hoạt động" : "Đã vô hiệu hóa")
                    </span>
                </div>

                <div class="profile-avatar-upload text-start">
                    <label class="form-label">Ảnh đại diện</label>
                    <InputFile class="form-control" OnChange="OnAvatarSelected" accept=".jpg,.jpeg,.png,.webp" />
                    @if (selectedAvatar is not null)
                    {
                        <div class="selected-file-chip"><i class="bi bi-image"></i> @selectedAvatar.Name</div>
                    }
                    <button class="btn btn-gradient-primary action-btn w-100 mt-3" type="button" disabled="@(selectedAvatar is null || isUploadingAvatar)" @onclick="UploadAvatarAsync">
                        <i class="bi bi-cloud-arrow-up"></i> @(isUploadingAvatar ? "Đang xử lý..." : "Tải ảnh đại diện")
                    </button>
                </div>
            </div>

            <div class="modern-card profile-card profile-quick-links slide-up">
                <div class="profile-card-header">
                    <div class="stat-icon"><i class="bi bi-lightning-charge"></i></div>
                    <div>
                        <h3 class="h5 fw-bold mb-0">Liên kết nhanh</h3>
                        <div class="text-muted small">Đi nhanh đến các chức năng theo vai trò.</div>
                    </div>
                </div>
                <div class="profile-quick-grid">
                    @foreach (var link in GetQuickLinks(profile.Role))
                    {
                        <a class="quick-action-card profile-quick-link hover-lift" href="@link.Url">
                            <span class="stat-icon"><i class="bi @link.Icon"></i></span>
                            <span>@link.Label</span>
                            <i class="bi bi-arrow-right-short quick-card-arrow"></i>
                        </a>
                    }
                </div>
            </div>
        </aside>

        <section class="profile-right">
            <div class="modern-card profile-card profile-info-card slide-up">
                <div class="profile-card-header">
                    <div class="stat-icon"><i class="bi bi-person-vcard"></i></div>
                    <div>
                        <h2 class="h5 fw-bold mb-0">Thông tin tài khoản</h2>
                        <div class="text-muted small">Thông tin định danh trong hệ thống.</div>
                    </div>
                </div>

                <div class="profile-info-grid">
                    <div class="profile-info-item"><span>Họ và tên</span><strong>@profile.FullName</strong></div>
                    <div class="profile-info-item"><span>Email</span><strong>@profile.Email</strong></div>
                    <div class="profile-info-item"><span>Vai trò</span><strong>@DisplayRole(profile.Role)</strong></div>
                    <div class="profile-info-item"><span>Số điện thoại</span><strong>@profile.PhoneNumber</strong></div>
                    <div class="profile-info-item profile-info-wide"><span>Địa chỉ</span><strong>@profile.Address</strong></div>
                    <div class="profile-info-item">
                        <span>Trạng thái tài khoản</span>
                        <span class="status-badge @(profile.IsActive ? "status-delivered" : "status-cancelled")">
                            @(profile.IsActive ? "Đang hoạt động" : "Đã vô hiệu hóa")
                        </span>
                    </div>
                    <div class="profile-info-item"><span>Ngày tạo</span><strong>@VietnamDateTime.Format(profile.CreatedAt)</strong></div>
                </div>
            </div>

            <div class="modern-card profile-card profile-form-card slide-up">
                <div class="profile-card-header">
                    <div class="stat-icon"><i class="bi bi-pencil-square"></i></div>
                    <div>
                        <h2 class="h5 fw-bold mb-0">Cập nhật hồ sơ</h2>
                        <div class="text-muted small">Email và vai trò không thể thay đổi tại đây.</div>
                    </div>
                </div>

                <EditForm Model="@profileForm" OnValidSubmit="UpdateProfileAsync">
                    <DataAnnotationsValidator />
                    <div class="profile-form-grid">
                        <div>
                            <label class="form-label">Họ và tên</label>
                            <InputText class="form-control" @bind-Value="profileForm.FullName" />
                            <ValidationMessage For="@(() => profileForm.FullName)" />
                        </div>
                        <div>
                            <label class="form-label">Số điện thoại</label>
                            <InputText class="form-control" @bind-Value="profileForm.PhoneNumber" />
                            <ValidationMessage For="@(() => profileForm.PhoneNumber)" />
                        </div>
                        <div class="profile-form-wide">
                            <label class="form-label">Địa chỉ</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="profileForm.Address" />
                            <ValidationMessage For="@(() => profileForm.Address)" />
                        </div>
                    </div>

                    <button class="btn btn-gradient-success action-btn mt-4" type="submit" disabled="@isSavingProfile">
                        <i class="bi bi-save"></i> @(isSavingProfile ? "Đang xử lý..." : "Cập nhật hồ sơ")
                    </button>
                </EditForm>
            </div>

            <div class="modern-card profile-card profile-form-card slide-up">
                <div class="profile-card-header">
                    <div class="stat-icon"><i class="bi bi-shield-lock"></i></div>
                    <div>
                        <h2 class="h5 fw-bold mb-0">Đổi mật khẩu</h2>
                        <div class="text-muted small">Mật khẩu mới cần đủ mạnh để bảo vệ tài khoản.</div>
                    </div>
                </div>

                <EditForm Model="@passwordForm" OnValidSubmit="ChangePasswordAsync">
                    <DataAnnotationsValidator />
                    <div class="password-grid">
                        <div>
                            <label class="form-label">Mật khẩu hiện tại</label>
                            <div class="input-group">
                                <InputText class="form-control" type="@(showCurrentPassword ? "text" : "password")" @bind-Value="passwordForm.CurrentPassword" />
                                <button class="btn btn-soft-secondary" type="button" title="@(showCurrentPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")" @onclick="() => showCurrentPassword = !showCurrentPassword">
                                    <i class="bi @(showCurrentPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => passwordForm.CurrentPassword)" />
                        </div>
                        <div>
                            <label class="form-label">Mật khẩu mới</label>
                            <div class="input-group">
                                <InputText class="form-control" type="@(showNewPassword ? "text" : "password")" @bind-Value="passwordForm.NewPassword" />
                                <button class="btn btn-soft-secondary" type="button" title="@(showNewPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")" @onclick="() => showNewPassword = !showNewPassword">
                                    <i class="bi @(showNewPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => passwordForm.NewPassword)" />
                        </div>
                        <div>
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <div class="input-group">
                                <InputText class="form-control" type="@(showConfirmPassword ? "text" : "password")" @bind-Value="passwordForm.ConfirmPassword" />
                                <button class="btn btn-soft-secondary" type="button" title="@(showConfirmPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")" @onclick="() => showConfirmPassword = !showConfirmPassword">
                                    <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => passwordForm.ConfirmPassword)" />
                        </div>
                    </div>

                    <button class="btn btn-gradient-primary action-btn mt-4" type="submit" disabled="@isChangingPassword">
                        <i class="bi bi-key"></i> @(isChangingPassword ? "Đang xử lý..." : "Đổi mật khẩu")
                    </button>
                </EditForm>
            </div>
        </section>
    </div>
}

@code {
    private ProfileDto? profile;
    private UpdateProfileRequest profileForm = new();
    private ChangePasswordRequest passwordForm = new();
    private IBrowserFile? selectedAvatar;
    private bool isLoading = true;
    private bool isUploadingAvatar;
    private bool isSavingProfile;
    private bool isChangingPassword;
    private bool showCurrentPassword;
    private bool showNewPassword;
    private bool showConfirmPassword;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadProfileAsync();
        StateHasChanged();
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            isLoading = true;
            var response = await ProfileApi.GetMyProfileAsync();

            if (response?.Success == true && response.Data is not null)
            {
                profile = response.Data;
                profileForm = new UpdateProfileRequest
                {
                    FullName = profile.FullName,
                    PhoneNumber = profile.PhoneNumber,
                    Address = profile.Address
                };
                await AuthService.UpdateCurrentUserFromProfileAsync(profile);
            }
            else
            {
                errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
            }
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnAvatarSelected(InputFileChangeEventArgs args)
    {
        selectedAvatar = args.File;
        ClearMessages();
    }

    private async Task UploadAvatarAsync()
    {
        if (selectedAvatar is null)
        {
            errorMessage = "Vui lòng chọn file ảnh.";
            return;
        }

        ClearMessages();
        isUploadingAvatar = true;

        try
        {
            var response = await UploadApi.UploadAvatarAsync(selectedAvatar);

            if (response?.Success == true)
            {
                successMessage = "Tải ảnh đại diện thành công.";
                selectedAvatar = null;
                await LoadProfileAsync();
            }
            else
            {
                errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
            }
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isUploadingAvatar = false;
        }
    }

    private async Task UpdateProfileAsync()
    {
        ClearMessages();
        isSavingProfile = true;

        try
        {
            var response = await ProfileApi.UpdateProfileAsync(profileForm);

            if (response?.Success == true && response.Data is not null)
            {
                successMessage = "Cập nhật hồ sơ thành công.";
                profile = response.Data;
                await AuthService.UpdateCurrentUserFromProfileAsync(profile);
            }
            else
            {
                errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
            }
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isSavingProfile = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        ClearMessages();
        isChangingPassword = true;

        try
        {
            var response = await ProfileApi.ChangePasswordAsync(passwordForm);

            if (response?.Success == true)
            {
                successMessage = "Đổi mật khẩu thành công.";
                passwordForm = new ChangePasswordRequest();
            }
            else
            {
                errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
            }
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isChangingPassword = false;
        }
    }

    private void ClearMessages()
    {
        successMessage = null;
        errorMessage = null;
    }

    private static string DisplayRole(string role)
    {
        return role switch
        {
            "Customer" => "Khách hàng",
            "Seller" => "Người bán",
            "Shipper" => "Người giao hàng",
            "Admin" => "Quản trị viên",
            _ => role
        };
    }

    private static string GetInitial(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "?"
            : value.Trim()[0].ToString().ToUpper();
    }

    private static List<QuickLink> GetQuickLinks(string role)
    {
        return role switch
        {
            "Customer" =>
            [
                new("Đơn hàng của tôi", "/my-orders", "bi-receipt"),
                new("Giỏ hàng", "/cart", "bi-cart3"),
                new("Thanh toán", "/payments", "bi-wallet2")
            ],
            "Seller" =>
            [
                new("Bảng điều khiển người bán", "/seller-dashboard", "bi-speedometer2"),
                new("Quản lý sản phẩm", "/seller-products", "bi-box-seam"),
                new("Đơn hàng người bán", "/seller-orders", "bi-receipt")
            ],
            "Shipper" =>
            [
                new("Đơn cần giao", "/shipper-orders", "bi-truck"),
                new("Lịch sử giao hàng", "/delivery-history", "bi-clock-history")
            ],
            "Admin" =>
            [
                new("Bảng điều khiển quản trị", "/admin-dashboard", "bi-speedometer2"),
                new("Người dùng", "/admin-users", "bi-people"),
                new("Báo cáo", "/admin-reports", "bi-file-earmark-bar-graph")
            ],
            _ => []
        };
    }

    private sealed record QuickLink(string Label, string Url, string Icon);
}
