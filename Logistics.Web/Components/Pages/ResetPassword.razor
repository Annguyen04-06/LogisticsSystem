@page "/reset-password"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Đặt lại mật khẩu</PageTitle>

<div class="auth-page auth-page-modern">
    <div class="auth-floating-shape shape-one"></div>
    <div class="auth-floating-shape shape-two"></div>

    <div class="auth-card auth-shell slide-up">
        <section class="auth-brand">
            <div class="auth-brand-mark">LS</div>
            <h1>Hệ thống quản lý Logistics</h1>
            <p>Tạo mật khẩu mới an toàn để bảo vệ tài khoản và dữ liệu giao dịch của bạn.</p>
            <div class="auth-brand-points">
                <span><i class="bi bi-key"></i> Mã đặt lại</span>
                <span><i class="bi bi-lock"></i> Mật khẩu mạnh</span>
                <span><i class="bi bi-check-circle"></i> Đăng nhập lại</span>
            </div>
        </section>

        <section class="auth-form">
            <div class="mb-4">
                <h2 class="auth-title">Đặt lại mật khẩu</h2>
                <p class="auth-subtitle">Nhập mã được gửi qua email và mật khẩu mới.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@resetPasswordRequest" OnValidSubmit="HandleResetPassword">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control auth-input"
                               @bind-Value="resetPasswordRequest.Email"
                               placeholder="Nhập email của bạn" />
                    <ValidationMessage For="@(() => resetPasswordRequest.Email)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mã đặt lại mật khẩu</label>
                    <InputText class="form-control auth-input"
                               @bind-Value="resetPasswordRequest.Token"
                               placeholder="Nhập mã đặt lại mật khẩu" />
                    <ValidationMessage For="@(() => resetPasswordRequest.Token)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mật khẩu mới</label>
                    <div class="input-group auth-password-group">
                        <InputText class="form-control auth-input"
                                   type="@(showNewPassword ? "text" : "password")"
                                   @bind-Value="resetPasswordRequest.NewPassword"
                                   placeholder="Nhập mật khẩu mới" />
                        <button class="btn btn-outline-secondary auth-password-toggle"
                                type="button"
                                title="@(showNewPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")"
                                @onclick="ToggleNewPasswordVisibility">
                            <i class="bi @(showNewPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => resetPasswordRequest.NewPassword)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <div class="input-group auth-password-group">
                        <InputText class="form-control auth-input"
                                   type="@(showConfirmPassword ? "text" : "password")"
                                   @bind-Value="resetPasswordRequest.ConfirmPassword"
                                   placeholder="Nhập lại mật khẩu mới" />
                        <button class="btn btn-outline-secondary auth-password-toggle"
                                type="button"
                                title="@(showConfirmPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")"
                                @onclick="ToggleConfirmPasswordVisibility">
                            <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => resetPasswordRequest.ConfirmPassword)" />
                </div>

                <button class="btn auth-button w-100" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "Đang xử lý..." : "Đặt lại mật khẩu")
                </button>
            </EditForm>

            <div class="text-center mt-4">
                <a class="auth-link" href="login">Quay lại đăng nhập</a>
            </div>
        </section>
    </div>
</div>

@code {
    private readonly ResetPasswordRequest resetPasswordRequest = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isSubmitting;
    private bool showNewPassword;
    private bool showConfirmPassword;

    private void ToggleNewPasswordVisibility()
    {
        showNewPassword = !showNewPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private async Task HandleResetPassword()
    {
        errorMessage = null;
        successMessage = null;
        isSubmitting = true;

        try
        {
            var response = await AuthService.ResetPasswordAsync(resetPasswordRequest);

            if (response?.Success == true)
            {
                successMessage = "Đặt lại mật khẩu thành công. Đang chuyển đến trang đăng nhập...";
                await Task.Delay(1500);
                Navigation.NavigateTo("/login");
                return;
            }

            errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
