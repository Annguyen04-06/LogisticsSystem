@page "/my-orders"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject OrderApiService OrderApiService
@inject NavigationManager Navigation

<PageTitle>Đơn hàng của tôi</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Đơn hàng của tôi</h1>
        <p class="page-subtitle">Theo dõi trạng thái xử lý và giao hàng.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state">Đang tải dữ liệu...</div>
}
else if (orders.Count == 0)
{
    <div class="empty-state">Chưa có dữ liệu.</div>
}
else
{
    <div class="d-grid gap-3 fade-in">
        @foreach (var order in orders)
        {
            <div class="modern-card customer-order-card hover-lift p-4">
                <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                    <div class="d-flex gap-3">
                        <div class="product-card-icon">
                            <i class="bi bi-receipt"></i>
                        </div>
                        <div>
                            <h2 class="h5 fw-bold mb-1">Mã đơn #@order.Id</h2>
                            <div class="text-muted small">Ngày tạo: @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            <div class="text-muted small">Người bán: @order.SellerName</div>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="status-badge @GetStatusBadgeClass(order.Status)">@GetVietnameseStatus(order.Status)</span>
                        @if (order.Status == "Pending")
                        {
                            <div class="mt-2 d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-soft-warning action-btn" @onclick="() => CancelOrderAsync(order.Id)">
                                    <i class="bi bi-x-circle"></i> Hủy
                                </button>
                                <button class="btn btn-sm btn-gradient-primary action-btn" @onclick="() => GoToPayment(order.Id)">
                                    <i class="bi bi-wallet2"></i> Thanh toán
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-card-title">Tổng tiền</div>
                            <div class="stat-card-value">@FormatMoney(order.TotalAmount)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-card-title">Giảm giá</div>
                            <div class="stat-card-value">@FormatMoney(order.DiscountAmount)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-card-title">Thành tiền</div>
                            <div class="stat-card-value">@FormatMoney(order.FinalAmount)</div>
                        </div>
                    </div>
                </div>

                <div class="modern-table-wrapper">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle modern-table mb-0">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in order.Details)
                                {
                                    <tr>
                                        <td class="fw-semibold">@detail.ProductName</td>
                                        <td>@detail.Quantity</td>
                                        <td>@FormatMoney(detail.UnitPrice)</td>
                                        <td class="fw-bold">@FormatMoney(detail.TotalPrice)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<OrderDto> orders = [];
    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadOrdersAsync();
        StateHasChanged();
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        var response = await OrderApiService.GetMyOrdersAsync();
        orders = response?.Data ?? [];
        isLoading = false;
    }

    private async Task CancelOrderAsync(int orderId)
    {
        successMessage = null;
        errorMessage = null;

        var response = await OrderApiService.CancelOrderAsync(orderId);

        if (response?.Success == true)
        {
            successMessage = "Đã hủy đơn hàng.";
            await LoadOrdersAsync();
            return;
        }

        errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    private void GoToPayment(int orderId)
    {
        Navigation.NavigateTo($"/payments?orderId={orderId}");
    }

    private static string GetVietnameseStatus(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "Confirmed" => "status-confirmed",
            "Shipping" => "status-shipping",
            "Delivered" => "status-delivered",
            "Cancelled" => "status-cancelled",
            _ => "text-bg-secondary"
        };
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} đ";
    }
}
