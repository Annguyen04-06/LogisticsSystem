@page "/my-orders"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject OrderApiService OrderApiService
@inject NavigationManager Navigation

<PageTitle>Đơn hàng của tôi</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Đơn hàng của tôi</h1>
        <p class="page-subtitle">Theo dõi trạng thái đơn hàng và chi tiết sản phẩm đã đặt.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="modern-card p-4 text-center text-muted">Đang tải đơn hàng...</div>
}
else if (orders.Count == 0)
{
    <div class="modern-card p-4 text-center text-muted">Bạn chưa có đơn hàng nào.</div>
}
else
{
    <div class="d-grid gap-3">
        @foreach (var order in orders)
        {
            <div class="modern-card p-4">
                <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                    <div>
                        <h2 class="h5 fw-bold mb-1">Mã đơn #@order.Id</h2>
                        <div class="text-muted small">Ngày tạo: @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="text-muted small">Người bán: @order.SellerName</div>
                    </div>
                    <div class="text-end">
                        <span class="status-badge @GetStatusBadgeClass(order.Status)">@GetVietnameseStatus(order.Status)</span>
                        @if (order.Status == "Pending")
                        {
                            <div class="mt-2">
                                <button class="btn btn-sm btn-warning" @onclick="() => CancelOrderAsync(order.Id)">Hủy</button>
                                <button class="btn btn-sm btn-primary ms-1" @onclick="() => GoToPayment(order.Id)">Thanh toán</button>
                            </div>
                        }
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-label">Tổng tiền</div>
                            <div class="stat-value">@order.TotalAmount.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-label">Giảm giá</div>
                            <div class="stat-value">@order.DiscountAmount.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-label">Thành tiền</div>
                            <div class="stat-value">@order.FinalAmount.ToString("N0")</div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Đơn giá</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in order.Details)
                            {
                                <tr>
                                    <td>@detail.ProductName</td>
                                    <td>@detail.Quantity</td>
                                    <td>@detail.UnitPrice.ToString("N0") VND</td>
                                    <td>@detail.TotalPrice.ToString("N0") VND</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<OrderDto> orders = [];
    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadOrdersAsync();
        StateHasChanged();
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        var response = await OrderApiService.GetMyOrdersAsync();
        orders = response?.Data ?? [];
        isLoading = false;
    }

    private async Task CancelOrderAsync(int orderId)
    {
        successMessage = null;
        errorMessage = null;

        var response = await OrderApiService.CancelOrderAsync(orderId);

        if (response?.Success == true)
        {
            successMessage = "Đã hủy đơn hàng.";
            await LoadOrdersAsync();
            return;
        }

        errorMessage = response?.Message ?? "Không thể hủy đơn hàng.";
    }

    private void GoToPayment(int orderId)
    {
        Navigation.NavigateTo($"/payments?orderId={orderId}");
    }

    private static string GetVietnameseStatus(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "Confirmed" => "status-confirmed",
            "Shipping" => "status-shipping",
            "Delivered" => "status-delivered",
            "Cancelled" => "status-cancelled",
            _ => "text-bg-secondary"
        };
    }
}
