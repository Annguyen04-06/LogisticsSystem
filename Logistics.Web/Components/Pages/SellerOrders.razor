@page "/seller/orders"
@page "/seller-orders"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject SellerOrderApiService SellerOrderApiService
@inject DeliveryApiService DeliveryApiService
@inject UserApiService UserApiService
@inject NavigationManager Navigation

<PageTitle>Đơn hàng người bán</PageTitle>

<div class="page-header fade-in">
    <div>
        <h1 class="page-title">Đơn hàng người bán</h1>
        <p class="page-subtitle">Xác nhận đơn hàng và gán người giao hàng khả dụng cho đơn đã xác nhận.</p>
    </div>
    <button class="btn btn-soft-primary action-btn" type="button" @onclick="LoadPageDataAsync" disabled="@isLoading">
        <i class="bi bi-arrow-repeat"></i> Tải lại
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-modern assign-success-alert fade-in d-flex align-items-center gap-2">
        <i class="bi bi-check-circle"></i>
        <span>@successMessage</span>
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-modern fade-in">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state">
        <i class="bi bi-arrow-repeat"></i>
        Đang tải dữ liệu...
    </div>
}
else
{
    @if (shippers.Count == 0)
    {
        <div class="alert alert-warning alert-modern">
            <i class="bi bi-exclamation-triangle"></i>
            Chưa có người giao hàng khả dụng.
        </div>
    }

    <div class="modern-card table-card seller-order-table-card modern-table-wrapper fade-in">
        <div class="admin-card-header">
            <div class="stat-icon"><i class="bi bi-receipt"></i></div>
            <div>
                <h2>Danh sách đơn hàng</h2>
                <p>Xác nhận đơn và gán người giao hàng đang hoạt động.</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle modern-table mb-0">
                <thead>
                    <tr>
                        <th class="table-id">Mã đơn</th>
                        <th>Khách hàng</th>
                        <th class="table-money">Tổng tiền</th>
                        <th class="table-money">Thành tiền</th>
                        <th class="table-status">Đơn hàng</th>
                        <th class="table-status">Thanh toán</th>
                        <th>Phương thức</th>
                        <th>Ngày tạo</th>
                        <th style="min-width: 260px;">Người giao hàng</th>
                        <th class="table-actions">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (orders.Count == 0)
                    {
                        <tr>
                            <td colspan="10">
                                <div class="empty-state">
                                    <i class="bi bi-inbox"></i>
                                    Chưa có dữ liệu.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in orders)
                        {
                            <tr>
                                <td class="table-id">#@order.Id</td>
                                <td>@order.CustomerName</td>
                                <td class="currency-value table-money">@FormatCurrency(order.TotalAmount)</td>
                                <td class="fw-bold currency-value table-money">@FormatCurrency(order.FinalAmount)</td>
                                <td class="table-status">
                                    <span class="status-badge @GetStatusBadgeClass(order.Status)">
                                        @GetVietnameseStatus(order.Status)
                                    </span>
                                </td>
                                <td class="table-status">
                                    <span class="status-badge @GetPaymentBadgeClass(order)">
                                        @GetPaymentStatusText(order)
                                    </span>
                                </td>
                                <td>
                                    <span class="small fw-semibold">@GetPaymentMethodText(order.PaymentMethod)</span>
                                </td>
                                <td>@VietnamDateTime.Format(order.CreatedAt)</td>
                                <td>
                                    @if (order.Status == "Confirmed")
                                    {
                                        <div class="shipper-select-wrap">
                                            <select class="form-select form-select-sm"
                                                    @bind="selectedShipperIds[order.Id]"
                                                    disabled="@(shippers.Count == 0)">
                                                <option value="0">Chọn người giao hàng</option>
                                                @foreach (var shipper in shippers)
                                                {
                                                    <option value="@shipper.Id">@GetShipperOptionText(shipper)</option>
                                                }
                                            </select>
                                            <button class="btn btn-sm btn-soft-primary action-btn"
                                                    type="button"
                                                    disabled="@(shippers.Count == 0)"
                                                    @onclick="() => AssignShipperAsync(order.Id)">
                                                <i class="bi bi-truck"></i> Gán
                                            </button>
                                        </div>
                                    }
                                    else if (order.ShipperId.HasValue)
                                    {
                                        <span class="text-muted">Đã gán #@order.ShipperId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa cần gán</span>
                                    }
                                </td>
                                <td class="table-actions">
                                    @if (order.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-soft-success action-btn me-1"
                                                type="button"
                                                @onclick="() => ConfirmOrderAsync(order)">
                                            <i class="bi bi-check-circle"></i> Xác nhận đơn
                                        </button>
                                    }
                                    @if (order.Status != "Pending" && order.Status != "Confirmed")
                                    {
                                        <span class="text-muted small">Không có thao tác</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<OrderDto> orders = [];
    private List<AvailableShipperDto> shippers = [];
    private Dictionary<int, int> selectedShipperIds = [];
    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadPageDataAsync();
        StateHasChanged();
    }

    private Task LoadPageDataAsync()
    {
        return LoadPageDataAsync(true);
    }

    private async Task LoadPageDataAsync(bool clearMessages)
    {
        isLoading = true;

        if (clearMessages)
        {
            ClearMessages();
        }

        try
        {
            await LoadShippersAsync();
            await LoadOrdersAsync();
        }
        catch
        {
            errorMessage = "Không thể tải dữ liệu đơn hàng người bán.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadShippersAsync()
    {
        var response = await UserApiService.GetActiveShippersAsync();

        if (response?.Success == true)
        {
            shippers = response.Data ?? [];
            return;
        }

        shippers = [];
        errorMessage = response?.Message ?? "Không thể tải danh sách người giao hàng.";
    }

    private async Task LoadOrdersAsync()
    {
        var response = await SellerOrderApiService.GetSellerOrdersAsync();

        if (response?.Success == true)
        {
            orders = response.Data ?? [];
            SyncSelectedShippers();
            return;
        }

        orders = [];
        errorMessage = response?.Message ?? "Không thể tải đơn hàng người bán.";
    }

    private void SyncSelectedShippers()
    {
        foreach (var order in orders)
        {
            if (!selectedShipperIds.ContainsKey(order.Id))
            {
                selectedShipperIds[order.Id] = order.ShipperId ?? 0;
            }
        }
    }

    private async Task ConfirmOrderAsync(OrderDto order)
    {
        ClearMessages();

        if (order.PaymentMethod is "Wallet" or "BankingDemo" &&
            (!order.IsPaid || order.PaymentStatus != "Paid"))
        {
            errorMessage = "Đơn hàng chưa được thanh toán nên chưa thể xác nhận.";
            return;
        }

        var response = await DeliveryApiService.ConfirmOrderAsync(order.Id);
        if (response?.Success == true)
        {
            successMessage = "Xác nhận đơn thành công.";
            await LoadPageDataAsync(false);
            _ = HideSuccessMessageAfterDelayAsync();
            return;
        }

        errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    private async Task AssignShipperAsync(int orderId)
    {
        ClearMessages();

        if (!selectedShipperIds.TryGetValue(orderId, out var shipperId) || shipperId <= 0)
        {
            errorMessage = "Vui lòng chọn người giao hàng.";
            return;
        }

        var selectedShipper = shippers.FirstOrDefault(shipper => shipper.Id == shipperId);
        var shipperName = selectedShipper?.FullName ?? $"người giao hàng #{shipperId}";

        var response = await DeliveryApiService.AssignShipperAsync(orderId, new AssignShipperDto
        {
            ShipperId = shipperId
        });

        if (response?.Success == true)
        {
            successMessage = $"Đã gán đơn hàng #{orderId} cho {shipperName} thành công.";
            selectedShipperIds[orderId] = shipperId;
            await LoadPageDataAsync(false);
            _ = HideSuccessMessageAfterDelayAsync();
            return;
        }

        errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    private void ClearMessages()
    {
        successMessage = null;
        errorMessage = null;
    }

    private async Task HideSuccessMessageAfterDelayAsync()
    {
        await Task.Delay(TimeSpan.FromSeconds(4));
        successMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    private static string GetShipperOptionText(AvailableShipperDto shipper)
    {
        return string.IsNullOrWhiteSpace(shipper.PhoneNumber)
            ? shipper.FullName
            : $"{shipper.FullName} - {shipper.PhoneNumber}";
    }

    private static string FormatCurrency(decimal value)
    {
        return $"{value:N0} đ";
    }

    private static string GetVietnameseStatus(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "Confirmed" => "status-confirmed",
            "Shipping" => "status-shipping",
            "Delivered" => "status-delivered",
            "Cancelled" => "status-cancelled",
            _ => "text-bg-secondary"
        };
    }

    private static string GetPaymentStatusText(OrderDto order)
    {
        if (order.PaymentMethod == "COD")
        {
            return "Thanh toán khi nhận hàng";
        }

        return order.PaymentStatus switch
        {
            "Paid" => "Đã thanh toán",
            "Refunded" => "Đã hoàn tiền",
            "Failed" => "Thanh toán thất bại",
            _ => "Chưa thanh toán"
        };
    }

    private static string GetPaymentBadgeClass(OrderDto order)
    {
        if (order.PaymentMethod == "COD")
        {
            return "badge-soft-secondary";
        }

        return order.PaymentStatus switch
        {
            "Paid" => "badge-soft-success",
            "Refunded" => "badge-soft-info",
            "Failed" => "badge-soft-danger",
            _ => "badge-soft-warning"
        };
    }

    private static string GetPaymentMethodText(string method)
    {
        return method switch
        {
            "COD" => "Thanh toán khi nhận hàng",
            "Wallet" => "Ví điện tử",
            "BankingDemo" => "Chuyển khoản giả lập",
            _ => method
        };
    }
}
