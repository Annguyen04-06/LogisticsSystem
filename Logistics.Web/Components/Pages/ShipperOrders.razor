@page "/shipper/orders"
@page "/shipper-orders"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject DeliveryApiService DeliveryApiService
@inject NavigationManager Navigation

<PageTitle>Đơn cần giao</PageTitle>

<div class="page-header fade-in">
    <div>
        <h1 class="page-title">Đơn cần giao</h1>
        <p class="page-subtitle">Cập nhật trạng thái giao hàng được phân công.</p>
    </div>
    <button class="btn btn-soft-primary action-btn" @onclick="LoadDeliveriesAsync">
        <i class="bi bi-arrow-repeat"></i> Tải lại
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-modern fade-in">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-modern fade-in">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state"><i class="bi bi-arrow-repeat"></i> Đang tải dữ liệu...</div>
}
else if (deliveries.Count == 0)
{
    <div class="empty-state"><i class="bi bi-truck"></i> Chưa có đơn hàng cần giao.</div>
}
else
{
    <div class="row g-3 fade-in">
        @foreach (var delivery in deliveries)
        {
            <div class="col-lg-6 col-xxl-4">
                <div class="modern-card shipper-delivery-card shipper-board-card hover-lift h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div class="d-flex gap-3">
                            <div class="shipper-card-icon">
                                <i class="bi bi-truck"></i>
                            </div>
                            <div>
                                <span class="delivery-id-chip"><i class="bi bi-truck"></i> Giao hàng #@delivery.Id</span>
                                <h2 class="h5 fw-bold mt-2 mb-1">Mã đơn #@delivery.OrderId</h2>
                                <div class="text-muted small">Người giao hàng: @delivery.ShipperName</div>
                            </div>
                        </div>
                        <span class="status-badge @GetStatusBadgeClass(delivery.Status)">@GetVietnameseStatus(delivery.Status)</span>
                    </div>

                    <div class="shipper-meta-list mb-3">
                        <div>
                            <span>Mã đơn</span>
                            <strong>#@delivery.OrderId</strong>
                        </div>
                        <div>
                            <span>Trạng thái</span>
                            <strong>@GetVietnameseStatus(delivery.Status)</strong>
                        </div>
                        <div>
                            <span>Ngày nhận đơn</span>
                            <strong>@VietnamDateTime.Format(delivery.AssignedAt)</strong>
                        </div>
                        <div>
                            <span>Ngày giao xong</span>
                            <strong>@VietnamDateTime.Format(delivery.DeliveredAt)</strong>
                        </div>
                    </div>

                    <div class="delivery-action-row mt-auto">
                        @if (delivery.Status == "Confirmed")
                        {
                            <button class="btn btn-gradient-primary action-btn" @onclick="() => StartShippingAsync(delivery.Id)">
                                <i class="bi bi-truck"></i> Bắt đầu giao
                            </button>
                        }
                        @if (delivery.Status == "Shipping")
                        {
                            <button class="btn btn-soft-success action-btn" @onclick="() => CompleteDeliveryAsync(delivery.Id)">
                                <i class="bi bi-check-circle"></i> Hoàn tất giao hàng
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<DeliveryDto> deliveries = [];
    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDeliveriesAsync();
        StateHasChanged();
    }

    private async Task LoadDeliveriesAsync()
    {
        isLoading = true;
        successMessage = null;
        errorMessage = null;

        try
        {
            var response = await DeliveryApiService.GetShipperOrdersAsync();
            if (response?.Success == true)
            {
                deliveries = response.Data ?? [];
            }
            else
            {
                errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
            }
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatusAsync(int deliveryId, string status)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            var response = await DeliveryApiService.UpdateDeliveryStatusAsync(deliveryId, status);

            if (response?.Success == true)
            {
                successMessage = status == "Shipping"
                    ? "Đã bắt đầu giao hàng."
                    : "Đã hoàn tất giao hàng.";
                await LoadDeliveriesAsync();
                return;
            }

            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
    }

    private Task StartShippingAsync(int deliveryId)
    {
        return UpdateStatusAsync(deliveryId, "Shipping");
    }

    private Task CompleteDeliveryAsync(int deliveryId)
    {
        return UpdateStatusAsync(deliveryId, "Delivered");
    }

    private static string GetVietnameseStatus(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "Confirmed" => "status-confirmed",
            "Shipping" => "status-shipping",
            "Delivered" => "status-delivered",
            "Cancelled" => "status-cancelled",
            _ => "text-bg-secondary"
        };
    }
}
