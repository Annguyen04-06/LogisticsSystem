@page "/shipper/orders"
@page "/shipper-orders"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject DeliveryApiService DeliveryApiService
@inject NavigationManager Navigation

<PageTitle>Đơn cần giao</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Đơn cần giao</h1>
        <p class="page-subtitle">Các đơn giao hàng đã được phân công và cần xử lý.</p>
    </div>
    <button class="btn btn-outline-primary" @onclick="LoadDeliveriesAsync">Tải lại</button>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="modern-card p-4 text-center text-muted">Đang tải dữ liệu...</div>
}
else
{
    <div class="modern-card table-card">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Mã giao hàng</th>
                    <th>Mã đơn</th>
                    <th>Người giao hàng</th>
                    <th>Trạng thái</th>
                    <th>Ngày nhận đơn</th>
                    <th>Ngày giao xong</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (deliveries.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Không có đơn cần giao.</td>
                    </tr>
                }
                else
                {
                    @foreach (var delivery in deliveries)
                    {
                        <tr>
                            <td>#@delivery.Id</td>
                            <td>#@delivery.OrderId</td>
                            <td>@delivery.ShipperName</td>
                            <td><span class="status-badge @GetStatusBadgeClass(delivery.Status)">@GetVietnameseStatus(delivery.Status)</span></td>
                            <td>@delivery.AssignedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(delivery.DeliveredAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td class="text-end">
                                @if (delivery.Status == "Confirmed")
                                {
                                    <button class="btn btn-sm btn-primary me-1" @onclick="() => StartShippingAsync(delivery.Id)">
                                        Bắt đầu giao
                                    </button>
                                }
                                @if (delivery.Status == "Shipping")
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => CompleteDeliveryAsync(delivery.Id)">
                                        Hoàn tất giao hàng
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<DeliveryDto> deliveries = [];
    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDeliveriesAsync();
        StateHasChanged();
    }

    private async Task LoadDeliveriesAsync()
    {
        isLoading = true;
        successMessage = null;
        errorMessage = null;

        try
        {
            var response = await DeliveryApiService.GetShipperOrdersAsync();
            if (response?.Success == true)
            {
                deliveries = response.Data ?? [];
            }
            else
            {
                errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
            }
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatusAsync(int deliveryId, string status)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            var response = await DeliveryApiService.UpdateDeliveryStatusAsync(deliveryId, status);

            if (response?.Success == true)
            {
                successMessage = status == "Shipping"
                    ? "Đã bắt đầu giao hàng."
                    : "Đã hoàn tất giao hàng.";
                await LoadDeliveriesAsync();
                return;
            }

            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
    }

    private Task StartShippingAsync(int deliveryId)
    {
        return UpdateStatusAsync(deliveryId, "Shipping");
    }

    private Task CompleteDeliveryAsync(int deliveryId)
    {
        return UpdateStatusAsync(deliveryId, "Delivered");
    }

    private static string GetVietnameseStatus(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "Confirmed" => "status-confirmed",
            "Shipping" => "status-shipping",
            "Delivered" => "status-delivered",
            "Cancelled" => "status-cancelled",
            _ => "text-bg-secondary"
        };
    }
}
