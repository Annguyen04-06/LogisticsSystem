@page "/admin/dashboard"
@page "/admin-dashboard"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject AdminDashboardApiService DashboardApi
@inject NavigationManager Navigation

<PageTitle>Bảng điều khiển quản trị</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Bảng điều khiển quản trị</h1>
        <p class="page-subtitle">Tổng quan doanh thu, đơn hàng và người dùng trong hệ thống.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-state">Đang tải dữ liệu...</div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (dashboard is not null)
{
    <div class="row g-3 mb-4 fade-in">
        @StatCard("Tổng người dùng", dashboard.TotalUsers.ToString("N0"), "Khách hàng, người bán, người giao hàng", "bi-people")
        @StatCard("Tổng sản phẩm", dashboard.TotalProducts.ToString("N0"), "Sản phẩm trong hệ thống", "bi-box-seam")
        @StatCard("Tổng đơn hàng", dashboard.TotalOrders.ToString("N0"), "Tất cả đơn hàng", "bi-receipt")
        @StatCard("Tổng doanh thu", FormatCurrency(dashboard.TotalRevenue), "Chỉ tính đơn đã giao", "bi-cash-stack")
        @StatCard("Phiếu hỗ trợ", dashboard.TotalTickets.ToString("N0"), "Đang mở: " + dashboard.OpenTickets.ToString("N0"), "bi-headset")
        @StatCard("Đơn đã giao", dashboard.DeliveredOrders.ToString("N0"), "Đơn hàng hoàn tất", "bi-check2-circle")
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-sm-6">
            <div class="modern-card admin-mini-card p-3">
                <span class="status-badge status-pending">Chờ xác nhận @dashboard.PendingOrders.ToString("N0")</span>
            </div>
        </div>
        <div class="col-lg-3 col-sm-6">
            <div class="modern-card admin-mini-card p-3">
                <span class="status-badge status-confirmed">Đã xác nhận @dashboard.ConfirmedOrders.ToString("N0")</span>
            </div>
        </div>
        <div class="col-lg-3 col-sm-6">
            <div class="modern-card admin-mini-card p-3">
                <span class="status-badge status-shipping">Đang giao @dashboard.ShippingOrders.ToString("N0")</span>
            </div>
        </div>
        <div class="col-lg-3 col-sm-6">
            <div class="modern-card admin-mini-card p-3">
                <span class="status-badge status-cancelled">Đã hủy @dashboard.CancelledOrders.ToString("N0")</span>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-6">
            <div class="modern-card modern-table-wrapper slide-up">
                <div class="p-4 pb-2 d-flex align-items-center gap-3">
                    <div class="stat-card-icon"><i class="bi bi-calendar3"></i></div>
                    <div>
                        <h2 class="h5 fw-bold mb-0">Thống kê đơn hàng theo ngày</h2>
                        <div class="text-muted small">Doanh thu tính theo đơn đã giao.</div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle modern-table mb-0">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Số đơn</th>
                                <th>Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ordersByDate.Count == 0)
                            {
                                <tr>
                                    <td colspan="3"><div class="empty-state">Chưa có dữ liệu.</div></td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in ordersByDate)
                                {
                                    <tr>
                                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                        <td>@item.TotalOrders.ToString("N0")</td>
                                        <td class="fw-bold">@FormatCurrency(item.Revenue)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="modern-card modern-table-wrapper slide-up">
                <div class="p-4 pb-2 d-flex align-items-center gap-3">
                    <div class="stat-card-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <div>
                        <h2 class="h5 fw-bold mb-0">Thống kê đơn hàng theo tháng</h2>
                        <div class="text-muted small">Theo dõi xu hướng xử lý đơn hàng.</div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle modern-table mb-0">
                        <thead>
                            <tr>
                                <th>Năm</th>
                                <th>Tháng</th>
                                <th>Số đơn</th>
                                <th>Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ordersByMonth.Count == 0)
                            {
                                <tr>
                                    <td colspan="4"><div class="empty-state">Chưa có dữ liệu.</div></td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in ordersByMonth)
                                {
                                    <tr>
                                        <td>@item.Year</td>
                                        <td>@item.Month</td>
                                        <td>@item.TotalOrders.ToString("N0")</td>
                                        <td class="fw-bold">@FormatCurrency(item.Revenue)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private AdminDashboardDto? dashboard;
    private List<OrderStatisticsByDateDto> ordersByDate = [];
    private List<OrderStatisticsByMonthDto> ordersByMonth = [];
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDashboardAsync();
        StateHasChanged();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            var dashboardResponse = await DashboardApi.GetDashboardAsync();
            var dateResponse = await DashboardApi.GetOrdersByDateAsync();
            var monthResponse = await DashboardApi.GetOrdersByMonthAsync();

            if (dashboardResponse?.Success != true || dashboardResponse.Data is null)
            {
                errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
                return;
            }

            dashboard = dashboardResponse.Data;
            ordersByDate = dateResponse?.Data ?? [];
            ordersByMonth = monthResponse?.Data ?? [];
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatCurrency(decimal value)
    {
        return $"{value:N0} đ";
    }

    private static RenderFragment StatCard(string label, string value, string note, string icon) => @<div class="col-sm-6 col-xl-4 col-xxl-2">
        <div class="stat-card hover-lift h-100">
            <div class="stat-card-icon"><i class="bi @icon"></i></div>
            <div class="stat-card-title">@label</div>
            <div class="stat-card-value">@value</div>
            <div class="stat-card-description">@note</div>
        </div>
    </div>;
}
