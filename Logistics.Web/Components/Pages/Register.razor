@page "/register"

<PageTitle>Đăng ký</PageTitle>

<div class="auth-page">
    <div class="modern-card auth-card p-4">
        <h1 class="h4 fw-bold mb-1">Đăng ký tài khoản</h1>
        <p class="text-muted">Tạo tài khoản cho khách hàng, người bán hoặc người giao hàng.</p>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Họ và tên</label>
                <input class="form-control" />
            </div>
            <div class="col-12">
                <label class="form-label">Email</label>
                <input class="form-control" />
            </div>
            <div class="col-12">
                <label class="form-label">Mật khẩu</label>
                <input class="form-control" type="password" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Số điện thoại</label>
                <input class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Vai trò</label>
                <select class="form-select">
                    <option>Khách hàng</option>
                    <option>Người bán</option>
                    <option>Người giao hàng</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Địa chỉ</label>
                <input class="form-control" />
            </div>
        </div>

        <button class="btn btn-success w-100 mt-4">Tạo tài khoản</button>
        <div class="text-center mt-3">
            <a href="login">Đã có tài khoản? Đăng nhập</a>
        </div>
    </div>
</div>
