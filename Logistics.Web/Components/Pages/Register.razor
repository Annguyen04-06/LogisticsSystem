@page "/register"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Đăng ký</PageTitle>

<div class="auth-page auth-page-modern">
    <div class="auth-floating-shape shape-one"></div>
    <div class="auth-floating-shape shape-two"></div>

    <div class="auth-card auth-shell register-shell slide-up">
        <section class="auth-brand">
            <div class="auth-brand-mark">LS</div>
            <h1>Hệ thống quản lý Logistics</h1>
            <p>Quản lý đơn hàng, giao hàng, thanh toán và báo cáo trong một nền tảng.</p>
            <div class="auth-brand-points">
                <span><i class="bi bi-people"></i> Khách hàng</span>
                <span><i class="bi bi-shop"></i> Người bán</span>
                <span><i class="bi bi-graph-up-arrow"></i> Tăng trưởng</span>
            </div>
        </section>

        <section class="auth-form">
            <div class="mb-4">
                <h2 class="auth-title">Đăng ký tài khoản</h2>
                <p class="auth-subtitle">Tạo tài khoản để bắt đầu sử dụng hệ thống.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="auth-success-card fade-in slide-up">
                    <div class="auth-success-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div>
                        <h3>Đăng ký thành công!</h3>
                        <p>Đang chuyển đến trang đăng nhập...</p>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@registerRequest" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Họ và tên</label>
                        <InputText class="form-control auth-input" @bind-Value="registerRequest.FullName" placeholder="Nhập họ và tên" />
                        <ValidationMessage For="@(() => registerRequest.FullName)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <InputText class="form-control auth-input" @bind-Value="registerRequest.Email" placeholder="Nhập email" />
                        <ValidationMessage For="@(() => registerRequest.Email)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu</label>
                        <div class="input-group auth-password-group">
                            <InputText class="form-control auth-input" type="@(showPassword ? "text" : "password")" @bind-Value="registerRequest.Password" placeholder="Nhập mật khẩu" />
                            <button class="btn btn-outline-secondary auth-password-toggle"
                                    type="button"
                                    title="@(showPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")"
                                    @onclick="TogglePasswordVisibility">
                                <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <ValidationMessage For="@(() => registerRequest.Password)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <InputText class="form-control auth-input" @bind-Value="registerRequest.PhoneNumber" placeholder="Nhập số điện thoại" />
                        <ValidationMessage For="@(() => registerRequest.PhoneNumber)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Vai trò</label>
                        <InputSelect class="form-select auth-input" @bind-Value="registerRequest.Role">
                            <option value="0">Khách hàng</option>
                            <option value="1">Người bán</option>
                        </InputSelect>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Địa chỉ</label>
                        <InputText class="form-control auth-input" @bind-Value="registerRequest.Address" placeholder="Nhập địa chỉ" />
                        <ValidationMessage For="@(() => registerRequest.Address)" />
                    </div>
                </div>

                <button class="btn auth-button w-100 mt-4" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "Đang xử lý..." : "Tạo tài khoản")
                </button>
            </EditForm>

            <div class="text-center mt-4">
                <span class="text-muted">Đã có tài khoản?</span>
                <a class="auth-link" href="login">Đăng nhập</a>
            </div>
        </section>
    </div>
</div>

@code {
    private RegisterRequest registerRequest = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isSubmitting;
    private bool showPassword;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task HandleRegister()
    {
        errorMessage = null;
        successMessage = null;
        isSubmitting = true;

        try
        {
            var response = await AuthService.RegisterAsync(registerRequest);

            if (response?.Success == true)
            {
                successMessage = "Đăng ký thành công!";
                registerRequest = new RegisterRequest();
                await Task.Delay(1500);
                Navigation.NavigateTo("/login");
                return;
            }

            errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
