@page "/login"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Đăng nhập</PageTitle>

<div class="auth-page auth-page-modern">
    <div class="auth-floating-shape shape-one"></div>
    <div class="auth-floating-shape shape-two"></div>

    <div class="auth-card auth-shell slide-up">
        <section class="auth-brand">
            <div class="auth-brand-mark">LS</div>
            <h1>Hệ thống quản lý Logistics</h1>
            <p>Quản lý đơn hàng, giao hàng, thanh toán và báo cáo trong một nền tảng.</p>
            <div class="auth-brand-points">
                <span><i class="bi bi-box-seam"></i> Đơn hàng</span>
                <span><i class="bi bi-truck"></i> Giao hàng</span>
                <span><i class="bi bi-wallet2"></i> Thanh toán</span>
            </div>
        </section>

        <section class="auth-form">
            <div class="mb-4">
                <h2 class="auth-title">Đăng nhập</h2>
                <p class="auth-subtitle">Đăng nhập để tiếp tục sử dụng hệ thống.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="@loginRequest" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control auth-input" @bind-Value="loginRequest.Email" placeholder="Nhập email" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-group auth-password-group">
                        <InputText class="form-control auth-input" type="@(showPassword ? "text" : "password")" @bind-Value="loginRequest.Password" placeholder="Nhập mật khẩu" />
                        <button class="btn btn-outline-secondary auth-password-toggle"
                                type="button"
                                title="@(showPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")"
                                @onclick="TogglePasswordVisibility">
                            <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>

                <button class="btn auth-button w-100" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "Đang xử lý..." : "Đăng nhập")
                </button>
            </EditForm>

            <div class="text-center mt-3">
                <a class="auth-link" href="forgot-password">Quên mật khẩu?</a>
            </div>

            <div class="text-center mt-4">
                <span class="text-muted">Chưa có tài khoản?</span>
                <a class="auth-link" href="register">Đăng ký ngay</a>
            </div>
        </section>
    </div>
</div>

@code {
    private readonly LoginRequest loginRequest = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isSubmitting;
    private bool showPassword;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        successMessage = null;
        isSubmitting = true;

        try
        {
            var response = await AuthService.LoginAsync(loginRequest);

            if (response?.Success == true && response.Data != null)
            {
                successMessage = "Đăng nhập thành công.";
                Navigation.NavigateTo(GetRedirectUrl(response.Data.Role));
                return;
            }

            errorMessage = "Đăng nhập thất bại. Vui lòng kiểm tra email hoặc mật khẩu.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private static string GetRedirectUrl(string role)
    {
        return role switch
        {
            "Admin" => "/admin-dashboard",
            "Seller" => "/seller-dashboard",
            "Shipper" => "/shipper-orders",
            "Customer" => "/products",
            _ => "/products"
        };
    }
}
