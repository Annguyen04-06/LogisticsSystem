@page "/"

<PageTitle>Bảng điều khiển</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Bảng điều khiển</h1>
        <p class="page-subtitle">Truy cập nhanh vào không gian làm việc Logistics.</p>
    </div>
    <a class="btn btn-primary" href="products">Xem sản phẩm</a>
</div>

<div class="row g-3 mb-4 stat-grid-row">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Đơn hàng</div>
            <div class="stat-value">128</div>
            <div class="text-muted small">Tất cả vai trò</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Doanh thu</div>
            <div class="stat-value">86.4M</div>
            <div class="text-muted small">Đơn đã giao</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Sản phẩm</div>
            <div class="stat-value">54</div>
            <div class="text-muted small">Danh mục đang hoạt động</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Hỗ trợ khách hàng</div>
            <div class="stat-value">7</div>
            <div class="text-muted small">Phiếu hỗ trợ đang mở</div>
        </div>
    </div>
</div>

<div class="modern-card p-4">
    <h2 class="h5 fw-bold mb-3">Không gian làm việc theo vai trò</h2>
    <div class="row g-3">
        <div class="col-md-3">
            <a class="btn btn-outline-primary w-100" href="my-orders">Khách hàng</a>
        </div>
        <div class="col-md-3">
            <a class="btn btn-outline-success w-100" href="seller/dashboard">Người bán</a>
        </div>
        <div class="col-md-3">
            <a class="btn btn-outline-warning w-100" href="shipper/orders">Người giao hàng</a>
        </div>
        <div class="col-md-3">
            <a class="btn btn-outline-danger w-100" href="admin/dashboard">Quản trị viên</a>
        </div>
    </div>
</div>
