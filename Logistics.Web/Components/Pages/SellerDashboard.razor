@page "/seller/dashboard"
@page "/seller-dashboard"
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject SellerDashboardApiService SellerDashboardApiService
@inject NavigationManager Navigation

<PageTitle>Bảng điều khiển người bán</PageTitle>

<div class="page-header fade-in">
    <div>
        <h1 class="page-title">Bảng điều khiển người bán</h1>
        <p class="page-subtitle">Theo dõi sản phẩm, đơn hàng, doanh thu và độ uy tín của gian hàng.</p>
    </div>
    <a class="btn btn-gradient-primary action-btn" href="/seller-products">
        <i class="bi bi-plus-circle"></i> Quản lý sản phẩm
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-modern fade-in">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state"><i class="bi bi-arrow-repeat"></i> Đang tải dữ liệu...</div>
}
else if (dashboard != null)
{
    <div class="modern-card seller-hero-card mb-4 fade-in">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
            <div>
                <div class="analytics-eyebrow">Trung tâm người bán</div>
                <h2 class="admin-section-title">@dashboard.SellerName</h2>
                <p class="admin-section-subtitle">Nắm nhanh tình trạng vận hành, đơn cần xử lý và hiệu quả bán hàng.</p>
            </div>
            <div class="seller-status-row">
                <span class="status-badge status-pending">Chờ xác nhận @dashboard.PendingOrders.ToString("N0")</span>
                <span class="status-badge status-confirmed">Đã xác nhận @dashboard.ConfirmedOrders.ToString("N0")</span>
                <span class="status-badge status-shipping">Đang giao @dashboard.ShippingOrders.ToString("N0")</span>
                <span class="status-badge status-delivered">Đã giao @dashboard.DeliveredOrders.ToString("N0")</span>
                <span class="status-badge status-cancelled">Đã hủy @dashboard.CancelledOrders.ToString("N0")</span>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4 fade-in">
        @StatCard("Tổng sản phẩm", dashboard.TotalProducts.ToString("N0"), "Sản phẩm đang quản lý", "bi-box-seam")
        @StatCard("Tổng đơn hàng", dashboard.TotalOrders.ToString("N0"), "Tất cả trạng thái", "bi-receipt")
        @StatCard("Doanh thu", FormatCurrency(dashboard.TotalRevenue), "Đơn đã giao", "bi-cash-stack")
        @StatCard("Độ uy tín", $"{dashboard.TrustPercent:N1}%", $"{dashboard.TotalLikes:N0} thích / {dashboard.TotalDislikes:N0} không thích", "bi-hand-thumbs-up")
        @StatCard("Đơn chờ xác nhận", dashboard.PendingOrders.ToString("N0"), "Cần xử lý", "bi-hourglass-split")
        @StatCard("Đơn đã giao", dashboard.DeliveredOrders.ToString("N0"), "Hoàn tất", "bi-check2-circle")
    </div>

    <div class="modern-card admin-quick-section seller-dashboard-actions slide-up">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
                <h2 class="admin-section-title mb-1">Thao tác nhanh</h2>
                <div class="text-muted small">Đi đến các khu vực người bán thường dùng.</div>
            </div>
        </div>
        <div class="row g-3">
            @QuickCard("Quản lý sản phẩm", "Thêm, sửa và cập nhật ảnh", "bi-box-seam", "/seller-products")
            @QuickCard("Đơn hàng người bán", "Xác nhận và gán giao hàng", "bi-receipt", "/seller-orders")
            @QuickCard("Báo cáo", "Doanh thu và hiệu quả bán", "bi-file-earmark-bar-graph", "/admin-reports")
            @QuickCard("Hồ sơ cá nhân", "Thông tin tài khoản", "bi-person-circle", "/profile")
        </div>
    </div>
}

@code {
    private SellerDashboardDto? dashboard;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthService.LoadSessionAsync();

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDashboardAsync();
        StateHasChanged();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await SellerDashboardApiService.GetDashboardAsync();

            if (response?.Success == true)
            {
                dashboard = response.Data;
            }
            else
            {
                errorMessage = response?.Message ?? "Không thể tải bảng điều khiển người bán.";
            }
        }
        catch
        {
            errorMessage = "Không thể tải bảng điều khiển người bán.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatCurrency(decimal value)
    {
        return $"{value:N0} đ";
    }

    private static RenderFragment StatCard(string label, string value, string note, string icon) => @<div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card hover-lift h-100">
            <div class="stat-icon"><i class="bi @icon"></i></div>
            <div class="stat-card-title">@label</div>
            <div class="stat-card-value currency-value">@value</div>
            <div class="stat-card-description">@note</div>
        </div>
    </div>;

    private static RenderFragment QuickCard(string label, string note, string icon, string href) => @<div class="col-sm-6 col-xl-3">
        <a class="quick-action-card admin-quick-card hover-lift h-100" href="@href">
            <div class="stat-icon"><i class="bi @icon"></i></div>
            <div>
                <div class="fw-bold">@label</div>
                <div class="text-muted small">@note</div>
            </div>
            <i class="bi bi-arrow-right-short quick-card-arrow"></i>
        </a>
    </div>;
}
