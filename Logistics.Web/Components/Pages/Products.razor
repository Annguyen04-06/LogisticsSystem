@page "/products"
@inject ProductApiService ProductApiService
@inject CategoryApiService CategoryApiService
@inject CartApiService CartApiService
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Danh sách sản phẩm</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Danh sách sản phẩm</h1>
        <p class="page-subtitle">Tìm kiếm, lựa chọn và thêm sản phẩm vào giỏ hàng.</p>
    </div>
</div>

<div class="search-filter-card mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label class="form-label">Tìm kiếm</label>
            <input class="form-control" @bind="searchKeyword" placeholder="Nhập tên sản phẩm" />
        </div>
        <div class="col-lg-4">
            <label class="form-label">Danh mục</label>
            <select class="form-select" @bind="selectedCategoryId">
                <option value="0">Tất cả danh mục</option>
                @foreach (var category in categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-3">
            <button class="btn btn-gradient-primary w-100" @onclick="LoadProductsAsync">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="loading-state">Đang tải dữ liệu...</div>
}
else if (products.Count == 0)
{
    <div class="empty-state">Chưa có dữ liệu.</div>
}
else
{
    <div class="row g-3 fade-in">
        @foreach (var product in products)
        {
            <div class="col-md-6 col-xl-4">
                <div class="modern-card customer-product-card hover-lift h-100">
                    <div class="product-image-frame mb-3">
                        @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                        {
                            <img src="@GetProductImageUrl(product.ImageUrl)" alt="@product.Name" />
                        }
                        else
                        {
                            <div class="product-image-placeholder">
                                <i class="bi bi-box-seam"></i>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <span class="badge text-bg-info">@product.CategoryName</span>
                    </div>

                    <h2 class="h5 fw-bold mb-2">@product.Name</h2>
                    <p class="text-muted product-description">@product.Description</p>

                    <div class="d-flex justify-content-between align-items-end gap-3 mb-3">
                        <div>
                            <div class="money-text">@FormatMoney(product.Price)</div>
                            <div class="text-muted small">Tồn kho: @product.Quantity</div>
                            <div class="text-muted small">Người bán: @product.SellerName</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2 mt-auto">
                        <InputNumber class="form-control form-control-sm quantity-input"
                                     @bind-Value="product.QuantityToAdd" min="1" />
                        <button class="btn btn-sm btn-gradient-primary action-btn flex-grow-1" @onclick="() => AddToCartAsync(product)">
                            <i class="bi bi-cart3"></i> Thêm vào giỏ hàng
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ProductDto> products = [];
    private List<CategoryDto> categories = [];
    private string? searchKeyword;
    private int selectedCategoryId;
    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
        await LoadProductsAsync();
    }

    private async Task LoadCategoriesAsync()
    {
        var response = await CategoryApiService.GetCategoriesAsync();
        categories = response?.Data ?? [];
    }

    private async Task LoadProductsAsync()
    {
        successMessage = null;
        errorMessage = null;
        isLoading = true;

        int? categoryId = selectedCategoryId == 0 ? null : selectedCategoryId;
        var response = await ProductApiService.GetProductsAsync(searchKeyword, categoryId);
        products = response?.Data ?? [];

        foreach (var product in products)
        {
            product.QuantityToAdd = 1;
        }

        isLoading = false;
    }

    private async Task AddToCartAsync(ProductDto product)
    {
        successMessage = null;
        errorMessage = null;

        if (!AuthState.IsAuthenticated)
        {
            await AuthService.LoadSessionAsync();
        }

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (product.QuantityToAdd <= 0)
        {
            errorMessage = "Số lượng phải lớn hơn 0.";
            return;
        }

        if (product.QuantityToAdd > product.Quantity)
        {
            errorMessage = "Số lượng không được vượt quá tồn kho.";
            return;
        }

        try
        {
            var response = await CartApiService.AddToCartAsync(new AddToCartDto
            {
                ProductId = product.Id,
                Quantity = product.QuantityToAdd
            });

            if (response?.Success == true)
            {
                successMessage = "Đã thêm sản phẩm vào giỏ hàng.";
                return;
            }

            errorMessage = response?.Message ?? "Có lỗi xảy ra. Vui lòng thử lại.";
        }
        catch
        {
            errorMessage = "Có lỗi xảy ra. Vui lòng thử lại.";
        }
    }

    private static string FormatMoney(decimal value)
    {
        return $"{value:N0} đ";
    }

    private static string GetProductImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(imageUrl, UriKind.Absolute, out _))
        {
            return imageUrl;
        }

        return $"http://localhost:5203/{imageUrl.TrimStart('/')}";
    }
}
