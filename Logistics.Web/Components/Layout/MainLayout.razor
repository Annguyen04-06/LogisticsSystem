@inherits LayoutComponentBase
@implements IDisposable
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<div class="app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="app-main">
        <header class="topbar">
            <div class="topbar-heading">
                <div class="topbar-kicker">Hệ thống quản lý Logistics</div>
                <h1 class="topbar-title">Bảng điều khiển vận hành</h1>
            </div>

            <div class="topbar-user">
                <div class="user-avatar">
                    @if (!string.IsNullOrWhiteSpace(AuthState.CurrentUser?.AvatarUrl))
                    {
                        <img class="avatar-img" src="@AuthState.CurrentUser.AvatarUrl" alt="Ảnh đại diện" />
                    }
                    else
                    {
                        <span class="avatar-fallback">@GetInitial(AuthState.DisplayName)</span>
                    }
                </div>
                <div class="user-meta">
                    <div class="user-name">@AuthState.DisplayName</div>
                    <span class="role-badge">@AuthStateService.GetVietnameseRoleName(AuthState.CurrentRole)</span>
                </div>
                @if (AuthState.IsAuthenticated)
                {
                    <button class="btn btn-outline-danger btn-sm btn-modern" type="button" @onclick="LogoutAsync">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Đăng xuất</span>
                    </button>
                }
            </div>
        </header>

        <main class="page-container page-shell fade-in">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Đã xảy ra lỗi không mong muốn.
    <a href="." class="reload">Tải lại</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool sessionLoaded;

    protected override void OnInitialized()
    {
        AuthState.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || sessionLoaded)
        {
            return;
        }

        sessionLoaded = true;
        await AuthService.LoadSessionAsync();

        if (AuthState.IsAuthenticated)
        {
            await LoadProfileForTopbarAsync();
        }

        StateHasChanged();
    }

    private async Task LoadProfileForTopbarAsync()
    {
        try
        {
            await AuthService.RefreshCurrentUserAsync();
        }
        catch
        {
            // Avatar is optional for the topbar; page-level requests handle their own errors.
        }
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }

    private static string GetInitial(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "?"
            : value.Trim()[0].ToString().ToUpper();
    }
}
